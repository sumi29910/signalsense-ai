# Copy this file to .env and fill in your real keys. Never commit .env itself.

GEMINI_API_KEY=your_gemini_api_key_here
# Get from https://aistudio.google.com/apikey

QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
# Get free tier from https://cloud.qdrant.io

ENKRYPT_API_KEY=your_enkrypt_api_key_here
# Get from https://enkryptai.com — optional, code falls back to local
# rule-based safety check if this is not set

# --- Vertex AI (optional but recommended for the submission) ---
# Set GOOGLE_GENAI_USE_VERTEXAI=True + fill in the two lines below to route
# the ADK agent's Gemini calls through Vertex AI instead of the AI Studio
# key above. This is what makes ticking "Vertex AI" on the form honest.
# Requires: a GCP project with Vertex AI API enabled, and
# `gcloud auth application-default login` run once locally.
GOOGLE_GENAI_USE_VERTEXAI=False
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Google Cloud Storage (optional but recommended for the submission) ---
# Stores every analyzed frame permanently so violations can be audited later.
# Create a bucket at https://console.cloud.google.com/storage, then set:
GCS_BUCKET_NAME=your-bucket-name
# Also needs: gcloud auth application-default login (same as Vertex AI)
# If left unset, frames are still saved locally to uploads/ — nothing breaks.

# --- Google Maps (for REAL live traffic lookups by Genie) ---
# Get a key at https://console.cloud.google.com/google/maps-apis
# Enable the "Distance Matrix API" and set up billing (Maps APIs require
# billing even within the free monthly credit — you won't be charged for
# hackathon-scale usage, but a card must be on file).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
